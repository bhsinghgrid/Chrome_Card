{
  "manifest_version": 3,
  "name": "Google Dashboard Sidebar",
  "version": "1.0.0",
  "description": "Calendar + Gmail sidebar dashboard",
  "permissions": [
    "storage",
    "identity",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["js/api.js", "js/auth.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "oauth2": {
    "client_id": "542366028313-doo2p284e48ppbtfgv5cb1ra00kv2fso.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.readonly",
      "https://www.googleapis.com/auth/gmail.readonly"
    ]
  }
}